{
  "name": "hexanaut-clone",
  "version": "1.0.0",
  "description": "A multiplayer territory conquest game inspired by Hexanaut.io",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "dev:client": "vite",
    "dev:server": "nodemon server/index.js",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "build:client": "vite build",
    "build:server": "echo 'Server ready for production'",
    "build": "npm run build:client",
    "start": "node server/index.js",
    "lint": "eslint . --ext .js,.ts",
    "format": "prettier --write \"**/*.{js,ts,json,md}\""
  },
  "keywords": [
    "game",
    "multiplayer",
    "io-game",
    "pixijs",
    "socketio",
    "vite"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@gamestdio/timer": "^1.3.0",
    "canvas-confetti": "^1.9.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "howler": "^2.2.4",
    "matter-js": "^0.19.0",
    "nanoid": "^5.0.7",
    "pixi.js": "^8.1.0",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "vite": "^5.2.11"
  }
}
